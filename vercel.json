{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!sitemap\\.xml|robots\\.txt|manifest\\.webmanifest|sw\\.js|workbox-[^/]+\\.js).*)",
            "destination": "/index.html"
        }
    ],
    "functions": {
        "api/ai.ts": {
            "maxDuration": 60,
            "memory": 1024
        }
    }
}